# Bags SDK
# Get your API Key at: https://dev.bags.fm
BAGS_API_KEY=your-bags-api-key

# Solana RPC (Helius)
# Get your RPC URL and API Key at: https://helius.dev
HELIUS_RPC_URL=https://mainnet.helius-rpc.com/?api-key=your-key

# Wallet
# Generate keypair: solana-keygen new -o ~/.config/solana/bagos-keypair.json
BAGS_KEYPAIR_PATH=~/.config/solana/bagos-keypair.json

# Token Gate
# The $BOS token mint address (Launch via Bags CLI to obtain real address)
BOS_TOKEN_MINT=BagOS11111111111111111111111111111111111111
BOS_REQUIRED_BALANCE=10000
